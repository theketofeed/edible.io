# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  EDIBLE.IO ENVIRONMENT SETUP - HUGGINGFACE FIX                            ║
# ╚═══════════════════════════════════════════════════════════════════════════╝
# 
# This template shows all required environment variables for Edible.io to work
# including the newly fixed HuggingFace image generation feature.
#
# INSTRUCTIONS:
# 1. Copy this file to .env.local
# 2. Fill in your actual API keys
# 3. Restart your dev server (npm run dev)

# ─── HUGGINGFACE IMAGE GENERATION (NEW - FIX FOR MEAL IMAGES) ────────────────
# 🎯 This is the main fix for generating AI food photos instead of Unsplash
# 
# 1. Go to https://huggingface.co/settings/tokens
# 2. Create a new token (fine-grained access is fine)
# 3. Copy the token and paste it below
# 4. The backend will use this to generate FLUX.1-schnell food images
#
# Free tier: 1,000 requests/day, 2-5 seconds per image
VITE_HF_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Backend URL (for proxy calls)
VITE_BACKEND_URL=http://localhost:3001

# ─── CORE API KEYS ─────────────────────────────────────────────────────────
VITE_CLAUDE_API_KEY=sk-ant-...
VITE_GROQ_API_KEY=gsk_...
VITE_OCR_SPACE_API_KEY=your_ocr_space_key

# ─── SUPABASE ──────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGc...
VITE_SUPABASE_SERVICE_KEY=eyJhbGc...

# ─── DODO PAYMENTS ────────────────────────────────────────────────────────
DODO_API_KEY=sk_test_...
DODO_ENV=test_mode
DODO_WEBHOOK_SECRET=whsec_...
DODO_PRODUCT_PRO_MONTHLY=pdt_...
DODO_PRODUCT_PRO_ANNUAL=pdt_...
DODO_PRODUCT_FOUNDING=pdt_...

# ─── FRONTEND ─────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ═══════════════════════════════════════════════════════════════════════════
# DEPLOYMENT NOTE:
# When deploying to production:
# - Keep these same env vars but update with production values
# - Make sure VITE_BACKEND_URL points to your production backend
# - Frontend vars are exposed (safe to expose public keys like HF token)
# - Backend vars stay secure on server only
# ═══════════════════════════════════════════════════════════════════════════
